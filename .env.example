# =============================================================================
# Yamtrack — Local environment configuration
# Copy this file to `.env` and adjust the values for your setup.
#   cp .env.example .env
# =============================================================================

# --- Core ---------------------------------------------------------------------
# REQUIRED: a long, random string used by Django for cryptographic signing.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET=change-me-to-a-long-random-string

# Timezone used inside the container (IANA name).
TZ=Europe/Berlin

# Set to True only when you need the Django admin enabled.
ADMIN_ENABLED=False

# Disable Django debug mode in any non-local deployment.
DEBUG=False

# Comma-separated list of allowed hostnames. Use * for local play-around only.
ALLOWED_HOSTS=*

# Comma-separated list of CSRF trusted origins (e.g. https://yamtrack.example.com).
# CSRF=

# --- Cache / queue ------------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- User / file permissions (Linux host) -------------------------------------
PUID=1000
PGID=1000

# --- Optional integrations ----------------------------------------------------
# Most of these are only required if you actually use the integration.
# See src/config/settings.py for the full list.

# TMDB_API=
# TMDB_LANG=en
# TVDB_API_KEY=
# TVDB_PIN=
# MAL_API=
# IGDB_ID=
# IGDB_SECRET=
# TRAKT_API=
# TRAKT_API_SECRET=
# ANILIST_ID=
# ANILIST_SECRET=
# SIMKL_ID=
# SIMKL_SECRET=
# STEAM_API_KEY=
# HARDCOVER_API=
# COMICVINE_API=
# BGG_API_TOKEN=
